{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "CustomRequest": {
      "title": "Custom Request",
      "description": "A custom cake idea generated by AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerPrompt": { "type": "string" },
        "cakeName": { "type": "string" },
        "flavorProfile": { "type": "string" },
        "designConcept": { "type": "string" },
        "chefPitch": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "submitted", "confirmed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "cakeName", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "A signature cake order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "type": "object" }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profiles"
    },
    "/customRequests/{requestId}": {
      "schema": "CustomRequest",
      "description": "Custom cake designs and orders"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Standard menu orders"
    }
  }
}
