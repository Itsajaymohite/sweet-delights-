rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // 3. Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 128))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1024));
    }

    function isValidCustomRequest(data) {
      return data.userId == request.auth.uid
        && data.cakeName is string && data.cakeName.size() <= 128
        && data.flavorProfile is string && data.flavorProfile.size() <= 1000
        && data.designConcept is string && data.designConcept.size() <= 1000
        && data.chefPitch is string && data.chefPitch.size() <= 1000
        && data.status in ['draft', 'submitted', 'confirmed']
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    // --- Collection Rules ---

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt;
    }

    // Custom Requests Collection
    match /customRequests/{requestId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isEmailVerified() && isValidCustomRequest(incoming());
      
      allow update: if isSignedIn() && isOwner(existing().userId) 
        && (existing().status != 'confirmed') // 3. Terminal State Locking
        && isValidCustomRequest(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt;
        
      allow delete: if isSignedIn() && isOwner(existing().userId) && (existing().status == 'draft');
    }

    // Orders Collection
    match /orders/{orderId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isEmailVerified() 
        && incoming().userId == request.auth.uid
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;
    }
  }
}
